import json
import re
import requests
from flask import Flask, request, jsonify
from flask_cors import CORS

app = Flask(__name__)
CORS(app)

# --- CẤU HÌNH OPENROUTER ---
# Thay thế bằng OpenRouter API Key thực tế của bạn
OPENROUTER_API_KEY = "YOUR_SECRET_KEY" 
MODEL_NAME = "google/gemini-2.5-flash-lite"

def ask_gemini(prompt):
    """Hàm thực hiện gọi API OpenRouter"""
    try:
        response = requests.post(
            url="https://openrouter.ai/api/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {OPENROUTER_API_KEY}",
                "Content-Type": "application/json",
                "HTTP-Referer": "http://localhost",
                "X-Title": "Vocab AI Pro",
            },
            data=json.dumps({
                "model": MODEL_NAME,
                "messages": [{"role": "user", "content": prompt}],
                "response_format": { "type": "json_object" }
            })
        )
        res_json = response.json()
        return res_json['choices'][0]['message']['content']
    except Exception as e:
        print(f"Lỗi API: {str(e)}")
        return None

def clean_json(text):
    """Làm sạch JSON từ phản hồi của AI để đảm bảo là JSON hợp lệ"""
    if not text: return None
    text = re.sub(r'```json\s*', '', text)
    text = re.sub(r'\s*```', '', text)
    return text.strip()

# --- 1. HEALTH CHECK (Kiểm tra trạng thái AI Engine) ---
@app.route('/health', methods=['GET'])
def health_check():
    return jsonify({"status": "online"}), 200

# --- 2. TRA CỨU TỪ VỰNG (Dùng cho index.php) ---
@app.route('/get-vocab', methods=['GET'])
def get_vocab():
    word = request.args.get('word')
    if not word:
        return jsonify({"error": "Thiếu từ vựng"}), 400
        
    prompt = f"""
    Analyze the English word: "{word}".
    Return a JSON object with:
    "word", "ipa", "level" (A1-C2), "word_form",
    "definition_en", "definition_vi", "example_sentence", "synonyms", "antonyms".
    """
    result = ask_gemini(prompt)
    if result:
        try:
            return jsonify(json.loads(clean_json(result)))
        except:
            return jsonify({"error": "AI trả về sai cấu trúc JSON", "raw": result}), 500
    return jsonify({"error": "Lỗi kết nối AI"}), 500

# --- 3. TẠO CÂU HỎI TRẮC NGHIỆM (Dùng cho quiz.php) ---
@app.route('/quiz-sentence', methods=['GET'])
def quiz_sentence():
    word = request.args.get('word')
    if not word:
        return jsonify({"error": "Thiếu từ vựng"}), 400

    prompt = f"""
    Create a natural English sentence for the word '{word}'. 
    CRITICAL: You MUST replace the word '{word}' and any of its variations with exactly '_____'. 
    Return ONLY JSON: {{"sentence": "..."}}
    """
    result = ask_gemini(prompt)
    if result:
        try:
            data = json.loads(clean_json(result))
            sentence = data.get('sentence', '')
            
            # LỚP BẢO VỆ DỰ PHÒNG: Tự động "đục lỗ" nếu AI quên
            if '_____' not in sentence:
                sentence = re.sub(re.escape(word), '_____', sentence, flags=re.IGNORECASE)
                data['sentence'] = sentence
                
            return jsonify(data)
        except:
            return jsonify({"error": "Lỗi định dạng câu hỏi"}), 500
    return jsonify({"error": "Lỗi AI Engine"}), 500

# --- 4. AI COACH & TRÍCH XUẤT (Dùng cho essay_extract.php) ---
@app.route('/extract-vocab', methods=['POST'])
def extract_vocab():
    data = request.json
    essay = data.get('essay', '')
    requirement = data.get('requirement', 'Từ vựng cấp độ C1')

    prompt = f"""
    Analyze this essay: "{essay}"
    
    TASKS:
    1. Coaching: Provide a summary, 2 pros, and 2 cons. 
       CRITICAL: The coaching section (summary, pros, cons) MUST BE WRITTEN IN VIETNAMESE.
    2. Vocabulary: Extract advanced words based on: "{requirement}".
    
    Return ONLY JSON:
    {{
      "coaching": {{
        "summary": "...", "pros": ["...", "..."], "cons": ["...", "..."]
      }},
      "words": [
        {{
          "word": "...", "ipa": "...", "word_form": "...", "level": "...",
          "definition_en": "...", "definition_vi": "...", "example_sentence": "...",
          "suggested_category": "..."
        }}
      ]
    }}
    """
    result = ask_gemini(prompt)
    if result:
        try:
            return jsonify(json.loads(clean_json(result)))
        except:
            return jsonify({"error": "Lỗi dữ liệu trích xuất", "raw": result}), 500
    return jsonify({"error": "Lỗi kết nối AI"}), 500

if __name__ == '__main__':
    # Chạy trên port 5000
    app.run(host='0.0.0.0', port=5000, debug=True)

from flask import Flask, request, jsonify
from flask_cors import CORS
import requests
import json
import re

app = Flask(__name__)
CORS(app)

# --- CONFIGURATION ---
# Replace with your actual OpenRouter API Key
OPENROUTER_API_KEY = "YOUR_API_KEY" 
MODEL_NAME = "google/gemini-2.5-flash-lite"

def clean_json_response(raw_text):
    """
    Cleans AI output to ensure it is a valid Python Dictionary or List.
    Handles Markdown backticks and common AI character errors.
    """
    try:
        # 1. Strip Markdown code blocks (```json ... ```)
        clean_text = re.sub(r'```json', '', raw_text)
        clean_text = re.sub(r'```', '', clean_text)
        
        # 2. Extract the JSON object or array using Regex
        # Updated to handle both { } for single objects and [ ] for lists
        match = re.search(r'[\{\[].*[\}\]]', clean_text, re.DOTALL)
        if match:
            json_str = match.group(0)
            
            # 3. Fix common AI character errors (curly quotes)
            json_str = json_str.replace('“', '"').replace('”', '"').replace('’', "'")
            
            # 4. Attempt to parse
            return json.loads(json_str)
        
        return None
    except Exception as e:
        print(f"JSON Parsing Error: {e}")
        return None

def call_openrouter(system_prompt, user_prompt):
    """Standardized API call to OpenRouter with deterministic settings."""
    try:
        response = requests.post(
            url="https://openrouter.ai/api/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {OPENROUTER_API_KEY}",
                "Content-Type": "application/json",
                "HTTP-Referer": "http://localhost",
                "X-Title": "VocabAI_Pro"
            },
            data=json.dumps({
                "model": MODEL_NAME,
                "messages": [
                    {"role": "system", "content": system_prompt},
                    {"role": "user", "content": user_prompt}
                ],
                "temperature": 0.1, 
                "top_p": 0.9
            }),
            timeout=20 
        )
        
        data = response.json()
        if 'choices' in data:
            raw_content = data['choices'][0]['message']['content']
            return clean_json_response(raw_content)
        
        return None
    except Exception as e:
        print(f"Network Error: {e}")
        return None

# --- ENDPOINT 1: SINGLE WORD GENERATION (Used in index.php) ---
@app.route('/get-vocab', methods=['GET'])
def get_vocab():
    word = request.args.get('word')
    if not word:
        return jsonify({"error": "No word provided"}), 400

    system_prompt = "You are a dictionary API. Return ONLY raw JSON. No conversational text."
    
    user_prompt = f"""
    Analyze word: "{word}".
    Return ONE specific CEFR level: A1, A2, B1, B2, C1, or C2.
    
    JSON Format:
    {{
      "word": "{word}",
      "ipa": "phonetic",
      "word_form": "noun/verb/adj",
      "level": "PICK ONE: A1, A2, B1, B2, C1, or C2",
      "definition_en": "concise english definition",
      "definition_vi": "vietnamese translation",
      "example_sentence": "natural usage example",
      "synonyms": "comma, separated, synonyms",
      "antonyms": "comma, separated, antonyms"
    }}
    """

    result = call_openrouter(system_prompt, user_prompt)
    
    if result:
        return jsonify(result)
    else:
        return jsonify({"error": "Failed to generate vocab data"}), 500

# --- ENDPOINT 2: QUIZ SENTENCE GENERATION (Used in quiz.php) ---
@app.route('/quiz-sentence', methods=['GET'])
def quiz_sentence():
    word = request.args.get('word')
    if not word:
        return jsonify({"error": "No word provided"}), 400

    system_prompt = "You are a quiz generator. Return ONLY raw JSON."
    user_prompt = f"Create a sentence where '{word}' is missing. Replace it with exactly 5 underscores: _____. Return JSON: {{\"sentence\": \"...\"}}"

    result = call_openrouter(system_prompt, user_prompt)
    
    if result:
        return jsonify(result)
    else:
        return jsonify({"sentence": f"The word _____ means {word}."}), 200

# --- ENDPOINT 3: ESSAY VOCABULARY EXTRACTION (Used in essay_extract.php) ---
@app.route('/extract-vocab', methods=['POST'])
def extract_vocab():
    data = request.json
    essay = data.get('essay', '')
    requirement = data.get('requirement', 'C1 level words')
    
    if not essay:
        return jsonify({"error": "No essay provided"}), 400

    system_prompt = "You are a linguistic analyzer. Return ONLY raw JSON array. No conversational text."
    
    user_prompt = f"""
    Analyze the following essay and extract words that match this requirement: "{requirement}".
    For each word found, suggest a concise category name (e.g., 'lawyer' -> 'Law', 'photosynthesis' -> 'Science').
    
    Essay: "{essay}"
    
    Return a JSON ARRAY of objects:
    [
      {{
        "word": "word",
        "ipa": "phonetic",
        "word_form": "noun/verb/adj",
        "level": "CEFR Level",
        "definition_en": "concise english definition",
        "definition_vi": "vietnamese translation",
        "example_sentence": "the exact sentence from the essay containing the word",
        "suggested_category": "Category Name",
        "synonyms": "comma, separated, synonyms",
        "antonyms": "comma, separated, antonyms"
      }}
    ]
    """

    result = call_openrouter(system_prompt, user_prompt)
    
    if result:
        return jsonify(result)
    else:
        return jsonify({"error": "Failed to analyze essay"}), 500

if __name__ == '__main__':
    # Run on port 5000 as expected by the PHP backend
    app.run(port=5000, debug=True)
